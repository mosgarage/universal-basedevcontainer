{
  "name": "Universal Basedevcontainer (Minimal)",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TIMEZONE": "UTC",
      "LOCALE": "en_US.UTF-8",
      "USERNAME": "dev"
    }
  },
  "remoteUser": "dev",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace"
}